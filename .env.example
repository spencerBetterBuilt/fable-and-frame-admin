# Postgres connection string (Neon / Vercel Postgres). Get a dev branch's
# connection string from the Neon/Vercel dashboard — SQLite is not supported.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Stripe (test mode keys for V1 — swap for live keys when going to production)
STRIPE_SECRET_KEY="sk_test_..."
# For local dev, run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# (Stripe CLI) and paste the `whsec_...` it prints. In production this comes from
# the webhook endpoint's signing secret in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Single shared admin password — also used as the HMAC secret for the admin session cookie.
ADMIN_PASSWORD="change-me"
